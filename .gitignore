# 1. Pastikan .env sudah ada di .gitignore
# Isi .gitignore:
# .env
# node_modules/
# dist/

# 2. Tambahkan semua file ke staging
git add .

# 3. Cek status (pastikan .env TIDAK muncul di sini)
git status

# 4. Commit perubahan
git commit -m "Menambahkan halaman login, register, dan dashboard"

# 5. Upload ke GitHub
git push origin main
